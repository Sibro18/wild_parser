# Browser settings
HEADLESS=true 						# Run browser in headless mode

# Concurrency limits
MAX_CONCURRENT_ASYNC_TASKS=5 		# Maximum number of concurrent asyncio tasks
MAX_CONCURRENT_PAGES=5 				# Maximum number of concurrent pages in Playwright browser

# Parsing options
WITH_BASKET=true 					# Include basket data (true/false)
MAX_PAGES=5							# Maximum number of pages to parse
QUERY=пальто из натуральной шерсти	# Search query (in Russian)

# Price filter (values in RUB, integers)
PRICE_MIN=100 						# Minimum price in RUB. format: 100 = 1.00 rub
PRICE_MAX=1000000					# Maximum price in RUB. format: 1000000 = 10000.00 rub

# Output
REPORT_FILE=reports/wildberries_report.xlsx # Path to the output Excel report
