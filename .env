# Browser settings

# Run browser in headless mode
HEADLESS=true

# Concurrency limits

# Maximum number of concurrent asyncio tasks
MAX_CONCURRENT_ASYNC_TASKS=5
# Maximum number of concurrent pages in Playwright browser
MAX_CONCURRENT_PAGES=5

# Parsing options

# Include basket data (true/false)
WITH_BASKET=true
# Maximum number of pages to parse
MAX_PAGES=5
# Search query (in Russian)
QUERY=пальто из натуральной шерсти

# Price filter (values in RUB, integers)

# Minimum price in RUB. format: 100 = 1.00 rub
PRICE_MIN=100
# Maximum price in RUB. format: 1000000 = 10000.00 rub
PRICE_MAX=1000000

# Output

# Path to the output Excel report
REPORT_FILE=reports/wildberries_report.xlsx
